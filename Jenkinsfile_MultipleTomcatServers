pipeline{
    agent any
    tools{
        maven 'Maven 3.9.12'
    }
    parameters {
        string(name: 'TOMCAT_SERVER_IPS', defaultValue: '3.109.47.166,13.234.186.239,43.205.203.205', description: 'Comma-separated list of Tomcat server IPs')
    }
    stages{
        stage("git clone"){
            steps{
                git branch: 'main', credentialsId: 'dinesh31bitgit', url: 'https://github.com/dinesh31-bit/student-reg-webapp.git'
            }
        }
        // stage("maven clean package"){
        //     steps{
        //         sh "mvn clean package"
        //     }
        // }
        // stage("sonar scan"){
        //     steps{
        //         withCredentials([string(credentialsId: 'SonarQube', variable: 'sonar')]) {
        //             sh "mvn clean verify sonar:sonar -Dsonar.token=${sonar}"
        //         }
        //     }
        // }
        // stage("store code in nexus"){
        //     steps{
        //         sh "mvn clean deploy"
        //     }
        // }
        stage("deploy to tomcat server"){
            steps{
                script{
                    def tomcatip = params.TOMCAT_SERVER_IPS.tokenize(',')
                    sshagent(['tomcat-nodes']) {
                        for (ip in tomcatip){
                            sh """
                                ssh -o StrictHostKeyChecking=no ec2-user@${ip} sudo systemctl stop tomcat
                                scp -o StrictHostKeyChecking=no target/student-reg-webapp.war ec2-user@${ip}:/opt/tomcat/webapps/student-reg-webapp.war
                                ssh -o StrictHostKeyChecking=no ec2-user@${ip} sudo systemctl start tomcat
                            """
                        }
                    }
                }
            }
        }
    }
 post {
        always {
            cleanWs()
        }
        success {
        slackSend (channel: 'lic-appteam', color: "good", message: "Build - SUCCESS : ${env.JOB_NAME} #${env.BUILD_NUMBER} - URL: ${env.BUILD_URL}")
          sendEmail(
           "${env.JOB_NAME} - ${env.BUILD_NUMBER} - Build SUCCESS",
           "Build SUCCESS. Please check the console output at ${env.BUILD_URL}",
           'balajireddy.urs@gmail.com' )
        }
        failure {
         slackSend (channel: 'lic-appteam', color: "danger", message: "Build - FAILED : ${env.JOB_NAME} #${env.BUILD_NUMBER} - URL: ${env.BUILD_URL}")    
         sendEmail(
           "${env.JOB_NAME} - ${env.BUILD_NUMBER} - Build FAILED",
           "Build FAILED. Please check the console output at ${env.BUILD_URL}",
           'balajireddy.urs@gmail.com' )
        }
    }
}

def sendEmail(String subject, String body, String recipient) {
    emailext(
        subject: subject,
        body: body,
        to: recipient,
        mimeType: 'text/html'
    )
}