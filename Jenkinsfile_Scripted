node{
    def mavenHome= tool name: 'Maven 3.9.12', type: 'maven'
    def tomcat_ip = '13.235.18.8'
    stage("maven clean package"){
        sh "${mavenHome}/bin/mvn clean package"
    }
    stage("maven celan verify"){
        withCredentials([string(credentialsId: 'SonarQube', variable: 'sonar_qube')]) {
            sh "${mavenHome}/bin/mvn clean verify sonar:sonar -Dsonar.token: ${sonar_qube}"
        }
    }
    stage("maven clean deploy"){
        sh "${mavenHome}/bin/mvn clean deploy"
    }
    stage("deploy to tomcat"){
        sh "echo 'deploy to tomcat'"
        sshagent(['tomcat-shh-credentials']) {
            sh """
                ssh -o strightHostKeyChecking=no ec2-user@${tomcat_ip} sudo systemctl stop tomcat
                ssh -o strightHostKeyChecking=no ec2-user@${tomcat_ip} rm -f /opt/tomcat/webhook/student-reg-webapp.war
                scp -o strightHostKeyChecking=no target/student-reg-webapp.war ec2-user@${tomcat_ip}:/opt/tomcat/webapp/student-reg-webapp.war
                ssh -o strightHostKeyChecking=no ec2-user@${tomcat_ip} sudo systemctl start tomcat
            """
        }
    }
}