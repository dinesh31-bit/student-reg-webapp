@Library ('JenkinsSharedLib') _
properties([pipelineTriggers([githubPush()])])
node{
    def mavenHome= tool name: 'Maven 3.9.12', type: 'maven'
    def tomcat_ip = '52.66.208.131'
    try{
        stage("git clone"){
            git branch: 'main', credentialsId:'dinesh31bitgit', url:'https://github.com/dinesh31-bit/student-reg-webapp.git'
        }
        stage("maven clean and verify"){
            parllel(
                stage("maven clean package"){
                    sh "echo 'maven clean package'"
                    sh "${mavenHome}/bin/mvn clean package"
                }
                stage("maven clean verify"){
                    withCredentials([string(credentialsId: 'SonarQube', variable: 'sonar_qube')]) {
                        sh "${mavenHome}/bin/mvn clean verify sonar:sonar -Dsonar.token=${sonar_qube}"
                    }
                }
            )
        }
        stage("maven clean deploy"){
            sh "${mavenHome}/bin/mvn clean deploy"
        }
        stage("deploy to tomcat"){
            sh "echo 'deploy to tomcat'"
            sshagent(['tomcat-shh-credentials']) {
                sh """
                    ssh -o StrictHostKeyChecking=no ec2-user@${tomcat_ip} sudo systemctl stop tomcat
                    ssh -o StrictHostKeyChecking=no ec2-user@${tomcat_ip} rm -f /opt/tomcat/webapps/student-reg-webapp.war
                    scp -o StrictHostKeyChecking=no target/student-reg-webapp.war ec2-user@${tomcat_ip}:/opt/tomcat/webapps/student-reg-webapp.war
                    ssh -o StrictHostKeyChecking=no ec2-user@${tomcat_ip} sudo systemctl start tomcat
                """
            }
        }
    }
    catch(err){
        currentBuild.result='FAILURE'
    }
    finally{
        def buildStatus = currentBuild.result ?: 'SUCCESS'
        def colorcode='good'
        if (buildStatus == 'FAILURE'){
            colorcode='DANGER'
        }
         SendEmailNotification("${buildStatus}",'dineshreddypala31@gmail.com')
            SendSlackNotification('devops-notification', "${buildStatus}")

    }
}